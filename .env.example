# +Físio +Saúde — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env NUNCA deve ser commitado no GitHub.

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_publica_aqui
SUPABASE_SERVICE_KEY=sua_service_role_key_privada_aqui

# ── Node.js (legado — será removido) ─────────────────
PORT=3000
JWT_SECRET=coloque_um_segredo_forte_aqui
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# ── Kaggle API (para ingestão do dataset Heart Disease) ────────────────────
# Obtenha em: https://www.kaggle.com/settings → "Create New Token"
# O arquivo kaggle.json baixado contém username e key.
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_api_kaggle
