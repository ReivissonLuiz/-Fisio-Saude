# ══════════════════════════════════════════════════════
#  +Físio +Saúde — .gitignore
#  NUNCA commitar arquivos listados abaixo
# ══════════════════════════════════════════════════════

# ── Variáveis de ambiente e chaves sensíveis ──────────
.env
*.env
.env.*
!.env.example
python_supabase/.env

# ── Banco de dados legado (arquivos TXT) ──────────────
data/

# ── Node.js ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.spec

# ── Flutter / Dart ────────────────────────────────────
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/build/
flutter_app/pubspec.lock
*.g.dart

# ── IDEs e editores ───────────────────────────────────
.idea/
.vscode/settings.json
*.suo
*.user
.vs/

# ── Sistema operacional ───────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Credenciais e certificados ────────────────────────
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
